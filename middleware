// Middleware para validar a criação e atualização de filmes
const validateMovie = (req, res, next) => {
    const { title, director, year, genre } = req.body;
    const errors = [];

    if (!title || typeof title !== 'string' || title.trim() === '') {
        errors.push('O campo "title" é obrigatório e deve ser uma string válida.');
    }
    if (!director || typeof director !== 'string' || director.trim() === '') {
        errors.push('O campo "director" é obrigatório e deve ser uma string válida.');
    }
    if (!year || typeof year !== 'number' || year < 1888 || year > new Date().getFullYear()) {
        errors.push('O campo "year" é obrigatório e deve ser um ano válido.');
    }
    if (!genre || typeof genre !== 'string' || genre.trim() === '') {
        errors.push('O campo "genre" é obrigatório e deve ser uma string válida.');
    }

    if (errors.length > 0) {
        return res.status(400).json({ error: 'Falha na validação', details: errors });
    }

    next();
};

module.exports = validateMovie;
